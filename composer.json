{
    "name": "elproximus/abilities-bridge",
    "description": "WordPress MCP server plugin for executing WordPress Abilities via Claude AI",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "require": {
        "php": ">=7.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "brain/monkey": "^2.6",
        "mockery/mockery": "^1.6",
        "yoast/phpunit-polyfills": "^2.0",
        "squizlabs/php_codesniffer": "^3.13",
        "wp-coding-standards/wpcs": "^3.3",
        "dealerdirect/phpcodesniffer-composer-installer": "^1.2"
    },
    "autoload": {
        "psr-4": {
            "Abilities_Bridge\\": "includes/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Abilities_Bridge\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "test:unit": "phpunit --testsuite unit",
        "test:coverage": "phpunit --coverage-html coverage/"
    },
    "config": {
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}
